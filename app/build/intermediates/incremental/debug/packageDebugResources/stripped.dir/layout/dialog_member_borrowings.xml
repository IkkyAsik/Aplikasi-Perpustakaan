<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/card_background">

    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Buku yang Dipinjam oleh"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvMemberNameTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nama Anggota"
        android:textColor="@color/primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMemberBorrowings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tvNoBorrowings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Anggota ini sedang tidak meminjam buku."
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnClose"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Tutup"
        android:backgroundTint="@color/primary"
        android:textColor="@color/white"
        android:layout_marginTop="16dp" />

</LinearLayout>
